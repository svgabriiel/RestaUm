{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build RestaUm",
            "type": "shell",
            "command": "C:/mingw64/bin/g++.exe",
            "args": [
                "*.cpp",
                "-o",
                "C:/projetosPessoal/RestaUm_/output/RestaUm.exe",
                "-I", "C:/raylib-5.5_win64_mingw-w64/include",
                "-L", "C:/raylib-5.5_win64_mingw-w64/lib",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm",
                "-static",
                "-Wl,-subsystem,windows"
            ],
            "options": {
                "shell": {
                    "executable": "C:/Windows/System32/cmd.exe",
                    "args": ["/c"]
                },
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
